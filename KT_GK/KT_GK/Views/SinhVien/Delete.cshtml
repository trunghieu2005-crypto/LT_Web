@model KT_GK.Models.SinhVien

@{
    ViewData["Title"] = "Xóa Sinh viên";
}

<h3 class="text-danger">Bạn có chắc chắn muốn xóa sinh viên này không?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Mã SV</dt>
        <dd class="col-sm-10">@Model.MaSV</dd>
        
        <dt class="col-sm-2">Họ Tên</dt>
        <dd class="col-sm-10">@Model.HoTen</dd>

        <dt class="col-sm-2">Hình</dt>
        <dd class="col-sm-10">
            <img src="@Model.Hinh" style="width:150px" class="img-thumbnail" />
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="MaSV" />
        <input type="submit" value="Xác nhận Xóa" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>