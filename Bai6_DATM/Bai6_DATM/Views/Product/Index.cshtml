@model IEnumerable<Bai6_DATM.Models.Product>


@{
    ViewData["Title"] = "Index";
}

<h1>Danh sách sản phẩm</h1>

<a asp-action="Create">Thêm mới</a>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Price)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.ImageUrl)</th>
            <th>@Html.DisplayNameFor(model => model.Category)</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>

                <td>@Html.DisplayFor(modelItem => item.Price)</td>

                <td>@Html.DisplayFor(modelItem => item.Description)</td>

                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        var src = item.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? item.ImageUrl : (item.ImageUrl.StartsWith("/") ? item.ImageUrl : Url.Content("~/images/" + item.ImageUrl));
                        <img src="@src" width="100px" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Category.Name)
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Chi tiết</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>